// PASSmaster - 국가기술자격 필기 문제은행 (13종)
// 핵심 차별점: AI 오답분석 (misconception_map 기반, 오답별 "왜 틀렸는지" 제공)
// 배포(Vercel 서버리스): PostgreSQL(Supabase). Connection Pooling(6543) 사용 권장.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // Supabase pooling URL (port 6543, pgbouncer=true)
  directUrl = env("DIRECT_URL")     // Supabase direct URL (port 5432) — 마이그레이션용
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          String    @default("student") // student | admin | owner | teacher | branch_admin
  emailVerified Boolean   @default(false)
  academyId     Int?
  branchId      Int?
  groupId       Int?
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  academy          Academy?        @relation(fields: [academyId], references: [id])
  branch           AcademyBranch?  @relation("BranchUsers", fields: [branchId], references: [id])
  group            AcademyGroup?   @relation("GroupMembers", fields: [groupId], references: [id])
  managedBranches  AcademyBranch[] @relation("BranchManager")
  teachingGroups   AcademyGroup[]  @relation("GroupTeacher")

  enrollments      Enrollment[]
  answers          UserAnswer[]
  academyAnswers   AcademyUserAnswer[]
  mockSessions     MockSession[]
  wrongNotes       WrongNote[]
  learningProgress LearningProgress[]
  consents         UserConsent[]
  reports          QuestionReport[]
  customQuestions  AcademyCustomQuestion[] @relation("QuestionAuthor")
  trialCompletions TrialCompletion[]
}

model AcademyUserAnswer {
  id                Int      @id @default(autoincrement())
  userId            Int
  academyQuestionId Int
  selected          Int?
  isCorrect         Boolean?
  timeSpent         Int?
  answeredAt        DateTime @default(now())

  user     User                  @relation(fields: [userId], references: [id])
  question AcademyCustomQuestion @relation(fields: [academyQuestionId], references: [id])

  @@index([userId])
  @@index([academyQuestionId])
}

// 과정(자격증). 13종: 조리 4 · 제과 · 제빵 · 미용 4 · 이용 · 지게차 · 전기
model Course {
  id           Int      @id @default(autoincrement())
  slug         String   @unique // e.g. 'hansik', 'jegwa', 'skin', 'electric'
  name         String   // e.g. '한식조리기능사 필기'
  category     String?  // e.g. '조리', '미용', '기타'
  brand        String   @default("passmaster") // 노출 브랜드 구분(멀티사이트 대비)
  description  String?
  price        Int      @default(9900)
  durationDays Int      @default(30)
  freeTrialCount Int    @default(100) // 무료체험 문제 수
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)   // 목록 정렬 순서
  createdAt    DateTime @default(now())

  questions        Question[]
  enrollments      Enrollment[]
  mockSessions     MockSession[]
  learningProgress LearningProgress[]
  trialCompletions TrialCompletion[]
}

model Question {
  id          Int      @id @default(autoincrement())
  courseId    Int
  subject     String?  // 과목명
  content     String   // 문제 지문 (기존 stem)
  option1     String
  option2     String
  option3     String
  option4     String
  answer      Int      // 정답 번호 1~4 (기존 answer_index)
  explanation String?  // 전체 해설

  // 난이도: 문제은행 표준(low/medium/high). 기존 Int(1~3)에서 String으로 변경.
  difficulty  String   @default("medium")

  // ★★ AI 오답분석 (이 서비스의 핵심 차별점) ★★
  // 문제은행의 ai_analysis 객체를 통째로 저장(jsonb).
  //   { learning_objective, key_concept, study_reference,
  //     misconception_map: { "2": {concept_gap, remediation_topic,
  //       misconception_weight, correct_concept, remediation_tip}, ... } }
  // 사용자가 오답 N번을 고르면 misconception_map["N"]을 꺼내 "왜 틀렸는지" 표시.
  aiAnalysis  Json?

  // 문제은행 메타데이터
  questionPolarity String?  // positive | negative (부정형 여부)
  trapType         String?  // none | lookalike_term | partial_truth | ...
  keywordTags      Json?    // 키워드 태그 배열
  unitTag          String?  // 세부 단원
  requiresImage    Boolean  @default(false)
  imageDescription String?

  isFree      Boolean  @default(false) // 무료체험 포함 여부
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  course     Course           @relation(fields: [courseId], references: [id])
  answers    UserAnswer[]
  wrongNotes WrongNote[]
  reports    QuestionReport[]

  @@index([courseId])
  @@index([courseId, isFree])
  @@index([courseId, subject])
}

// 수강생 오류 신고 (문제/선택지/정답/해설 등)
model QuestionReport {
  id         Int       @id @default(autoincrement())
  questionId Int
  userId     Int
  category   String // question | option | answer | explanation | other
  detail     String
  status     String    @default("open") // open | resolved
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  question Question @relation(fields: [questionId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([status])
}

model Enrollment {
  id        Int       @id @default(autoincrement())
  userId    Int
  courseId  Int
  status      String    @default("pending") // pending|paid|active|expired|cancelled
  paidAt      DateTime?
  expiresAt   DateTime?
  amount      Int
  memo        String?
  userDeleted Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model UserAnswer {
  id            Int      @id @default(autoincrement())
  userId        Int
  questionId    Int
  sessionType   String // trial|round1|round2|round3|mock|wrong_round|wrong_mock
  sessionId     Int?
  selected      Int?
  isCorrect     Boolean?
  timeSpent     Int?
  shuffledOrder String?
  answeredAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@index([userId, sessionType])
}

model MockSession {
  id           Int       @id @default(autoincrement())
  userId       Int
  courseId     Int
  mockNumber   Int // 1~6
  difficulty   String // easy|normal|hard|real
  totalQ       Int       @default(60)
  correctCount Int       @default(0)
  score        Float?
  passScore    Float     @default(60)
  questionIds  String? // 생성된 문제 id 목록 (JSON)
  startedAt    DateTime?
  completedAt  DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

model WrongNote {
  id          Int       @id @default(autoincrement())
  userId      Int
  questionId  Int
  source      String // round2|round3|mock1..mock6
  wrongCount  Int       @default(1)
  lastWrongAt DateTime  @default(now())
  isResolved  Boolean   @default(false)

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId, source])
}

model UserConsent {
  id           Int      @id @default(autoincrement())
  userId       Int
  consentMode  String // trial | paid
  termsVersion String   @default("v1.0")
  examCategory String?
  agreedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, consentMode])
}

model TrialCompletion {
  id          Int      @id @default(autoincrement())
  userId      Int
  courseId    Int
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
}

model LearningProgress {
  id              Int      @id @default(autoincrement())
  userId          Int
  courseId        Int
  round1Done      Boolean  @default(false)
  round2Done      Boolean  @default(false)
  round3Done      Boolean  @default(false)
  wrongRoundDone  Boolean  @default(false)
  mockDone        Int      @default(0)
  wrongMockDone   Boolean  @default(false)
  lastRound       Int      @default(0)
  lastMock        Int      @default(0)
  lastQIndex      Int      @default(0)
  curStepKey      String   @default("")
  curStepPct      Int      @default(0)
  updatedAt       DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

// ── B2B 학원 화이트레이블 (기존 유지 — 나중에 B2B 실시간 AI 분석 차별점 얹을 자리) ──

model Academy {
  id           Int      @id @default(autoincrement())
  name         String
  brand        String   @default("passmaster") // passmaster | beautymaster | cookmaster
  tier         String // basic | standard | premium
  code         String?  @unique @db.VarChar(6)
  subdomain    String?  @unique
  logoUrl      String?
  primaryColor String   @default("#0F172A")
  ownerEmail   String
  ownerPhone   String?
  maxStudents  Int      @default(15)
  activeUntil  DateTime @db.Date
  createdAt    DateTime @default(now())

  users           User[]
  branches        AcademyBranch[]
  groups          AcademyGroup[]
  customQuestions AcademyCustomQuestion[]
  invites         AcademyInvite[]
  notices         AcademyNotice[]
}

model AcademyNotice {
  id        Int      @id @default(autoincrement())
  academyId Int
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([academyId])
}

model AcademyBranch {
  id        Int      @id @default(autoincrement())
  academyId Int
  name      String
  address   String?
  managerId Int?
  code      String?  @unique @db.VarChar(8)
  createdAt DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  manager User?   @relation("BranchManager", fields: [managerId], references: [id])
  groups  AcademyGroup[]
  users   User[]  @relation("BranchUsers")

  @@index([academyId])
}

model AcademyGroup {
  id        Int      @id @default(autoincrement())
  academyId Int
  branchId  Int?
  name      String
  teacherId Int?
  createdAt DateTime @default(now())

  academy Academy        @relation(fields: [academyId], references: [id], onDelete: Cascade)
  branch  AcademyBranch? @relation(fields: [branchId], references: [id])
  teacher User?          @relation("GroupTeacher", fields: [teacherId], references: [id])
  members User[]         @relation("GroupMembers")

  @@index([academyId])
}

model AcademyCustomQuestion {
  id          Int      @id @default(autoincrement())
  academyId   Int
  content     String
  options     Json
  answer      Int
  explanation String?
  aiAnalysis  Json?    // 학원 커스텀 문제도 오답분석 지원(선택)
  subject     String?
  difficulty  String   @default("medium")
  createdById Int?
  createdAt   DateTime @default(now())

  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("QuestionAuthor", fields: [createdById], references: [id])
  answers   AcademyUserAnswer[]

  @@index([academyId])
}

model AcademyInvite {
  id        Int       @id @default(autoincrement())
  academyId Int
  email     String
  role      String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([token])
}

model VisitReferrerDaily {
  id             Int      @id @default(autoincrement())
  date           DateTime @db.Date
  referrerDomain String
  visitCount     Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([date, referrerDomain])
  @@index([date])
}
