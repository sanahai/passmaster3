// BEAUTYmaster - 미용사 자격증 필기 문제은행
// 스펙(Chapter 5)을 기반으로 한 스키마.
// 배포(Vercel 서버리스)에서는 PostgreSQL(Neon/Vercel Postgres)을 사용합니다.
// 로컬 개발도 동일한 DATABASE_URL(클라우드 Postgres)을 사용하면 됩니다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          String    @default("student") // student | admin | owner | teacher | branch_admin
  emailVerified Boolean   @default(false)
  academyId     Int?
  branchId      Int?
  groupId       Int?
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  academy          Academy?        @relation(fields: [academyId], references: [id])
  branch           AcademyBranch?  @relation("BranchUsers", fields: [branchId], references: [id])
  group            AcademyGroup?   @relation("GroupMembers", fields: [groupId], references: [id])
  managedBranches  AcademyBranch[] @relation("BranchManager")
  teachingGroups   AcademyGroup[]  @relation("GroupTeacher")

  enrollments      Enrollment[]
  answers          UserAnswer[]
  academyAnswers   AcademyUserAnswer[]
  mockSessions     MockSession[]
  wrongNotes       WrongNote[]
  learningProgress LearningProgress[]
  consents         UserConsent[]
  reports          QuestionReport[]
  customQuestions  AcademyCustomQuestion[] @relation("QuestionAuthor")
}

model AcademyUserAnswer {
  id                Int      @id @default(autoincrement())
  userId            Int
  academyQuestionId Int
  selected          Int?
  isCorrect         Boolean?
  timeSpent         Int?
  answeredAt        DateTime @default(now())

  user     User                  @relation(fields: [userId], references: [id])
  question AcademyCustomQuestion @relation(fields: [academyQuestionId], references: [id])

  @@index([userId])
  @@index([academyQuestionId])
}

model Course {
  id           Int      @id @default(autoincrement())
  slug         String   @unique // e.g. 'beauty-general'
  name         String // e.g. '미용사(일반) 필기'
  category     String? // e.g. '미용사'
  description  String?
  price        Int      @default(39000)
  durationDays Int      @default(90)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  questions        Question[]
  enrollments      Enrollment[]
  mockSessions     MockSession[]
  learningProgress LearningProgress[]
}

model Question {
  id          Int      @id @default(autoincrement())
  courseId    Int
  subject     String? // 과목명
  content     String // 문제 지문
  option1     String
  option2     String
  option3     String
  option4     String
  answer      Int // 정답 번호 1~4
  explanation String?
  difficulty  Int      @default(2) // 1(쉬움)~3(어려움)
  isFree      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  course     Course           @relation(fields: [courseId], references: [id])
  answers    UserAnswer[]
  wrongNotes WrongNote[]
  reports    QuestionReport[]

  @@index([courseId])
}

// 수강생 오류 신고 (문제/선택지/정답/해설 등)
model QuestionReport {
  id         Int       @id @default(autoincrement())
  questionId Int
  userId     Int
  category   String // question | option | answer | explanation | other
  detail     String
  status     String    @default("open") // open | resolved
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  question Question @relation(fields: [questionId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([status])
}

model Enrollment {
  id        Int       @id @default(autoincrement())
  userId    Int
  courseId  Int
  status      String    @default("pending") // pending|paid|active|expired|cancelled
  paidAt      DateTime?
  expiresAt   DateTime?
  amount      Int
  memo        String?
  userDeleted Boolean   @default(false) // 회원이 삭제(숨김) 처리 — 기록은 보존
  createdAt   DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model UserAnswer {
  id            Int      @id @default(autoincrement())
  userId        Int
  questionId    Int
  sessionType   String // trial|round1|round2|round3|mock|wrong_round|wrong_mock
  sessionId     Int?
  selected      Int?
  isCorrect     Boolean?
  timeSpent     Int?
  shuffledOrder String?
  answeredAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@index([userId, sessionType])
}

model MockSession {
  id           Int       @id @default(autoincrement())
  userId       Int
  courseId     Int
  mockNumber   Int // 1~6
  difficulty   String // easy|normal|hard|real
  totalQ       Int       @default(60)
  correctCount Int       @default(0)
  score        Float?
  passScore    Float     @default(60)
  questionIds  String? // 생성된 문제 id 목록 (JSON)
  startedAt    DateTime?
  completedAt  DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

model WrongNote {
  id          Int       @id @default(autoincrement())
  userId      Int
  questionId  Int
  source      String // round2|round3|mock1..mock6
  wrongCount  Int       @default(1)
  lastWrongAt DateTime  @default(now())
  isResolved  Boolean   @default(false)

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId, source])
}

// 학습 시작/결제 전 안내·동의 기록 (법적 방어용)
model UserConsent {
  id           Int      @id @default(autoincrement())
  userId       Int
  consentMode  String // trial | paid
  termsVersion String   @default("v1.0")
  examCategory String? // 해당되는 경우 과정 카테고리/슬러그
  agreedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, consentMode])
}

model LearningProgress {
  id              Int      @id @default(autoincrement())
  userId          Int
  courseId        Int
  round1Done      Boolean  @default(false)
  round2Done      Boolean  @default(false)
  round3Done      Boolean  @default(false)
  wrongRoundDone  Boolean  @default(false)
  mockDone        Int      @default(0) // 완료한 모의고사 수 0~6
  wrongMockDone   Boolean  @default(false)
  lastRound       Int      @default(0)
  lastMock        Int      @default(0)
  lastQIndex      Int      @default(0)
  curStepKey      String   @default("") // 현재 진행 중인 단계 키 (round1..mock6, wrong_*)
  curStepPct      Int      @default(0) // 현재 단계 진행률 0~100 (이탈 시점 저장)
  updatedAt       DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

// ── B2B 학원 화이트레이블 ──

model Academy {
  id           Int      @id @default(autoincrement())
  name         String
  brand        String   @default("beautymaster") // beautymaster | cookmaster | passmaster
  tier         String // basic | standard | premium
  code         String?  @unique @db.VarChar(6)
  subdomain    String?  @unique
  logoUrl      String?
  primaryColor String   @default("#0F172A")
  ownerEmail   String
  ownerPhone   String?
  maxStudents  Int      @default(15)
  activeUntil  DateTime @db.Date
  createdAt    DateTime @default(now())

  users           User[]
  branches        AcademyBranch[]
  groups          AcademyGroup[]
  customQuestions AcademyCustomQuestion[]
  invites         AcademyInvite[]
  notices         AcademyNotice[]
}

model AcademyNotice {
  id        Int      @id @default(autoincrement())
  academyId Int
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([academyId])
}

model AcademyBranch {
  id        Int      @id @default(autoincrement())
  academyId Int
  name      String
  address   String?
  managerId Int?
  code      String?  @unique @db.VarChar(8)
  createdAt DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  manager User?   @relation("BranchManager", fields: [managerId], references: [id])
  groups  AcademyGroup[]
  users   User[]  @relation("BranchUsers")

  @@index([academyId])
}

model AcademyGroup {
  id        Int      @id @default(autoincrement())
  academyId Int
  branchId  Int?
  name      String
  teacherId Int?
  createdAt DateTime @default(now())

  academy Academy        @relation(fields: [academyId], references: [id], onDelete: Cascade)
  branch  AcademyBranch? @relation(fields: [branchId], references: [id])
  teacher User?          @relation("GroupTeacher", fields: [teacherId], references: [id])
  members User[]         @relation("GroupMembers")

  @@index([academyId])
}

model AcademyCustomQuestion {
  id          Int      @id @default(autoincrement())
  academyId   Int
  content     String
  options     Json
  answer      Int
  explanation String?
  subject     String?
  difficulty  Int      @default(2)
  createdById Int?
  createdAt   DateTime @default(now())

  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("QuestionAuthor", fields: [createdById], references: [id])
  answers   AcademyUserAnswer[]

  @@index([academyId])
}

model AcademyInvite {
  id        Int       @id @default(autoincrement())
  academyId Int
  email     String
  role      String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([token])
}
