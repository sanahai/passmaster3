# 로컬 개발용 PostgreSQL (Neon 등)
DATABASE_URL="postgresql://..."

# 세션 서명용 시크릿 (32자 이상 권장)
AUTH_SECRET="change-me-to-a-long-random-secret-string"

# 브랜드 (passmaster | cookmaster) — 배포별 설정
NEXT_PUBLIC_BRAND="passmaster"

# 사이트 URL (이메일·초대 링크용)
NEXT_PUBLIC_SITE_URL="https://passmaster.kr"

# Resend 이메일 (없으면 콘솔 stub)
RESEND_API_KEY=""
RESEND_FROM="PASSmaster <onboarding@resend.dev>"

# Vercel Cron 주간 리포트 (월요일 09:00 KST ≈ UTC 00:00)
CRON_SECRET="random-cron-secret"

# 알림톡 (Solapi 등 — 없으면 콘솔 stub)
ALIMTALK_API_KEY=""
ALIMTALK_SENDER_KEY=""
ALIMTALK_WEEKLY_TEMPLATE_ID=""
ALIMTALK_API_URL="https://api.solapi.com/messages/v4/send"
